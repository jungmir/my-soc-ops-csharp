<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="bg-mc-panel rounded-xl p-6 max-w-xs w-full text-center border-4 border-mc-block shadow-mc animate-[bounce_0.5s_ease-out]">
        <div class="text-5xl mb-4">🪓</div>
        <h2 class="text-3xl font-bold text-mc-wood mb-2">BINGO!</h2>
        <p class="text-mc-stone mb-6">You completed a row and earned your reward.</p>

        <button
            @onclick="OnDismiss"
            class="w-full bg-mc-wood text-white font-bold py-3 px-6 rounded-sm border-4 border-mc-block shadow-mc">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
