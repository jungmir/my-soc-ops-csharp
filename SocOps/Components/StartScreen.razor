<div class="flex flex-col items-center justify-center min-h-full p-6 mc-page">
    <div class="w-full max-w-md mx-auto p-6 border-4 border-mc-block rounded-xl bg-mc-panel shadow-mc">
        <div class="text-center mb-6">
            <h1 class="text-5xl font-bold text-mc-wood mb-2">Soc Ops</h1>
            <p class="text-lg text-mc-stone">Social Bingo adventure</p>
        </div>

        <div class="bg-mc-dirt-soft border-4 border-mc-block rounded-lg p-5 mb-7">
            <h2 class="font-bold text-mc-wood text-xl mb-3">Quest Log</h2>
            <ul class="text-left text-mc-stone text-sm space-y-2">
                <li>• Find people who match the questions</li>
                <li>• Tap a block when the trait is found</li>
                <li>• Complete a row to win the bingo challenge</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="w-full bg-mc-wood text-white font-bold py-4 px-6 rounded-sm border-4 border-mc-block shadow-mc text-lg transition-all duration-150">
            Start Adventure
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
