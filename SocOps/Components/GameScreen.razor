@using SocOps.Models

<div class="flex flex-col min-h-full mc-page">
    <!-- Header -->
    <header class="flex items-center justify-between p-4 bg-mc-grass border-b-4 border-mc-block">
        <button
            @onclick="OnReset"
            class="text-mc-wood text-sm px-3 py-2 rounded-sm border-4 border-mc-block bg-mc-panel">
            ← Back
        </button>
        <h1 class="font-bold text-2xl text-mc-wood">Soc Ops</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <div class="text-center py-4 px-4">
        <p class="text-mc-wood text-sm leading-tight">
            Explore the board and mark the blocks when you meet someone who matches the clue.
        </p>
    </div>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="mx-4 mb-4 border-4 border-mc-block rounded-sm bg-mc-wood text-white text-center py-3 font-bold text-sm shadow-mc">
            🎉 BINGO! You completed a row.
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3">
        <div class="w-full max-w-lg p-3 bg-mc-panel border-4 border-mc-block rounded-xl shadow-mc">
            <BingoBoard
                Board="@Board"
                WinningSquareIds="@WinningSquareIds"
                OnSquareClick="@OnSquareClick" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
