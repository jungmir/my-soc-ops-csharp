@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 text-white text-sm">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-2 text-center border-4 rounded-sm transition-all duration-150 select-none min-h-[60px] text-xs leading-tight";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "bg-[#f0d26d] border-[#bfa33f] text-[#3c2b10]"
                : "bg-mc-grass border-mc-block text-white"
            : Square.IsFreeSpace
                ? "bg-mc-grass border-mc-block text-mc-wood font-bold"
                : "bg-mc-dirt border-mc-block text-mc-wood active:bg-mc-stone";

        return $"{baseClasses} {stateClasses}";
    }
}
